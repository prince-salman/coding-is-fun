# ============================================================
# Konfigurasi Text-to-Speech (Gemini TTS)
# ============================================================
# API key diambil dari Google AI Studio: https://aistudio.google.com/apikey
#
# CATATAN PENTING:
#   - Salin file ini menjadi `.env` lalu isi nilainya.
#   - JANGAN commit file `.env` asli ke git (sudah diabaikan di .gitignore).
#   - File `.env.example` ini HANYA contoh, tanpa nilai rahasia.
#   - Di hosting production, set environment variable ini juga
#     (mis. di dashboard Vercel/Railway/Render, bukan di dalam repo).
#   - Key ini hanya dibaca di sisi server (Node) — tidak pernah
#     dikirim ke browser/client.
# ============================================================

GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Opsional: port server produksi (default 4173).
# PORT=4173
